---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Print Forge — Commercial 3D Printing &amp; Fabrication | New Zealand">
<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #060610;
    color: #e2e8f0;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }
  :root {
    --blue:    #2563eb;
    --purple:  #7c3aed;
    --pink:    #db2777;
    --dark:    #060610;
    --dark2:   #0b0b1c;
    --dark3:   #0f0f24;
    --dark4:   #13132e;
    --border:  rgba(255,255,255,0.08);
    --border2: rgba(255,255,255,0.05);
    --text:    #e2e8f0;
    --muted:   rgba(255,255,255,0.45);
    --muted2:  rgba(255,255,255,0.65);
    --grad:    linear-gradient(135deg, #2563eb 0%, #7c3aed 50%, #db2777 100%);
    --grad-h:  linear-gradient(135deg, #1d4ed8 0%, #6d28d9 50%, #be185d 100%);
    --grad-90: linear-gradient(90deg, #2563eb 0%, #7c3aed 50%, #db2777 100%);
  }
  .container { width: 100%; max-width: 1160px; margin: 0 auto; padding: 0 24px; }
  .section { padding: 96px 0; }
  h1,h2,h3,h4 { font-family: 'Space Grotesk', sans-serif; font-weight: 700; line-height: 1.12; color: #fff; }
  h2 { font-size: clamp(1.9rem, 3.2vw, 2.6rem); }
  h3 { font-size: 1.1rem; font-weight: 600; }
  p  { color: var(--muted2); }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    background: var(--grad);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 14px;
  }
  .eyebrow::before {
    content: '';
    display: inline-block; width: 20px; height: 2px;
    background: var(--grad); border-radius: 2px;
    -webkit-text-fill-color: initial;
    flex-shrink: 0;
  }
  .grad-text {
    background: var(--grad);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem; font-weight: 700;
    padding: 13px 26px; border-radius: 8px;
    transition: all 0.18s ease; cursor: pointer; border: none;
    white-space: nowrap;
  }
  .btn-primary { background: var(--grad); color: #fff; }
  .btn-primary:hover { background: var(--grad-h); transform: translateY(-1px); box-shadow: 0 8px 30px rgba(124,58,237,0.35); }
  .btn-outline { background: transparent; color: rgba(255,255,255,0.85); border: 1.5px solid var(--border); }
  .btn-outline:hover { border-color: rgba(124,58,237,0.6); color: #fff; }
  .btn-lg { padding: 16px 32px; font-size: 0.95rem; }
  .section-header { margin-bottom: 56px; }
  .section-header.center { text-align: center; }
  .section-header p { margin-top: 12px; max-width: 540px; }
  .section-header.center p { margin: 12px auto 0; }
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(6,6,16,0.85);
    backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid var(--border);
    transition: box-shadow 0.2s;
  }
  .nav-top-line { height: 3px; background: var(--grad); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-wordmark { font-family: 'Space Grotesk', sans-serif; font-size: 1.2rem; font-weight: 800; color: #fff; letter-spacing: -0.02em; }
  .nav-links { display: flex; align-items: center; gap: 28px; }
  .nav-links a { font-size: 0.85rem; font-weight: 500; color: var(--muted); transition: color 0.15s; }
  .nav-links a:hover { color: #fff; }
  .nav-cta { display: flex; align-items: center; gap: 10px; }
  .nav-portal { font-size: 0.8rem; font-weight: 600; color: var(--muted); border: 1.5px solid var(--border); padding: 8px 15px; border-radius: 7px; transition: all 0.15s; }
  .nav-portal:hover { color: #fff; border-color: rgba(124,58,237,0.5); }
  .nav-hamburger { display: none; background: none; border: none; cursor: pointer; color: #fff; padding: 4px; }
  .mobile-menu { display: none; flex-direction: column; background: var(--dark2); border-top: 1px solid var(--border); padding: 16px 24px 24px; gap: 4px; }
  .mobile-menu a { font-size: 0.92rem; font-weight: 500; color: var(--muted2); padding: 10px 0; border-bottom: 1px solid var(--border2); }
  .mobile-menu.open { display: flex; }
  .hero { min-height: 100vh; display: flex; align-items: center; position: relative; overflow: hidden; background: var(--dark); padding-top: 64px; }
  .hero-orbs { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.18; }
  .orb-1 { width: 600px; height: 600px; background: #2563eb; top: -15%; right: -10%; }
  .orb-2 { width: 400px; height: 400px; background: #7c3aed; bottom: 5%; left: 15%; }
  .orb-3 { width: 300px; height: 300px; background: #db2777; top: 30%; right: 25%; }
  .hero-grid-bg { position: absolute; inset: 0; z-index: 0; opacity: 0.03; background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 56px 56px; }
  .hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; padding: 80px 0 60px; }
  .hero-pill { display: inline-flex; align-items: center; gap: 10px; border: 1px solid rgba(124,58,237,0.35); background: rgba(124,58,237,0.1); border-radius: 100px; padding: 7px 16px 7px 8px; margin-bottom: 24px; }
  .hero-pill-dot { width: 28px; height: 28px; border-radius: 50%; background: var(--grad); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .hero-pill-dot svg { width: 13px; height: 13px; }
  .hero-pill-text { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.75); }
  .hero h1 { font-size: clamp(2.6rem, 4.8vw, 4rem); margin-bottom: 20px; letter-spacing: -0.02em; }
  .hero-sub { font-size: 1.1rem; color: var(--muted2); margin-bottom: 36px; max-width: 480px; line-height: 1.7; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-stats { display: flex; gap: 28px; margin-top: 44px; padding-top: 32px; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .stat-num { font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; font-weight: 800; background: var(--grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1; }
  .stat-label { font-size: 0.75rem; color: var(--muted); margin-top: 4px; }
  .hero-visual { position: relative; }
  .hero-main-card { background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; backdrop-filter: blur(10px); }
  .hero-main-card-top { padding: 0; background: linear-gradient(135deg, rgba(37,99,235,0.15) 0%, rgba(124,58,237,0.12) 50%, rgba(219,39,119,0.08) 100%); display: flex; align-items: center; justify-content: center; min-height: 280px; position: relative; overflow: hidden; }
  .hero-main-card-body { padding: 20px 24px; border-top: 1px solid var(--border); }
  .hero-card-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .hero-card-title { font-family: 'Space Grotesk', sans-serif; font-weight: 700; color: #fff; font-size: 0.95rem; margin-top: 3px; }
  .hero-card-meta { font-size: 0.78rem; color: var(--muted); margin-top: 6px; }
  .hero-sub-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px; }
  .hero-sub-card { background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 12px; padding: 16px; position: relative; overflow: hidden; }
  .hero-sub-card-bar { position: absolute; top: 0; left: 0; right: 0; height: 2px; }
  .hero-sub-card .hero-card-label { margin-top: 8px; }
  .hero-float-badge { position: absolute; top: 16px; right: 16px; background: rgba(6,6,16,0.8); border: 1px solid var(--border); border-radius: 8px; padding: 8px 12px; backdrop-filter: blur(12px); display: flex; align-items: center; gap: 8px; }
  .hero-float-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; animation: blink 2s ease-in-out infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .hero-float-badge-text { font-size: 0.72rem; font-weight: 600; color: #fff; }
  .trust-strip { background: var(--dark2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 20px 0; }
  .trust-inner { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 8px 28px; }
  .trust-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
  .trust-item { display: flex; align-items: center; gap: 7px; font-size: 0.8rem; color: var(--muted2); }
  .trust-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--purple); flex-shrink: 0; }
  .services-section { background: var(--dark); }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
  .svc-card { background: var(--dark2); padding: 32px 28px; transition: background 0.2s; position: relative; }
  .svc-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--grad); opacity: 0; transition: opacity 0.2s; }
  .svc-card:hover { background: var(--dark3); }
  .svc-card:hover::before { opacity: 1; }
  .svc-icon { width: 52px; height: 52px; border-radius: 12px; background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
  .svc-icon svg { width: 26px; height: 26px; }
  .svc-card h3 { color: #fff; margin-bottom: 10px; }
  .svc-card p { font-size: 0.875rem; line-height: 1.7; }
  .svc-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 16px; }
  .tag { display: inline-block; font-size: 0.7rem; font-weight: 600; background: rgba(124,58,237,0.12); color: rgba(167,139,250,0.9); border: 1px solid rgba(124,58,237,0.2); border-radius: 4px; padding: 3px 9px; letter-spacing: 0.04em; }
  .apps-section { background: var(--dark3); }
  .apps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 14px; }
  .app-card { background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 12px; padding: 22px 18px; transition: border-color 0.2s, background 0.2s; position: relative; overflow: hidden; }
  .app-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: var(--grad); opacity: 0; transition: opacity 0.2s; }
  .app-card:hover { border-color: rgba(124,58,237,0.4); background: rgba(124,58,237,0.06); }
  .app-card:hover::after { opacity: 1; }
  .app-icon-wrap { width: 44px; height: 44px; border-radius: 10px; background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.15); display: flex; align-items: center; justify-content: center; font-size: 1.25rem; margin-bottom: 12px; }
  .app-card h4 { font-size: 0.9rem; color: #fff; margin-bottom: 5px; }
  .app-card p { font-size: 0.79rem; line-height: 1.6; }
  .why-section { background: var(--dark); }
  .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .why-list { display: flex; flex-direction: column; gap: 18px; margin-top: 28px; }
  .why-item { display: flex; gap: 14px; align-items: flex-start; }
  .why-num { width: 32px; height: 32px; flex-shrink: 0; border-radius: 8px; background: var(--grad); display: flex; align-items: center; justify-content: center; font-family: 'Space Grotesk', sans-serif; font-size: 0.75rem; font-weight: 800; color: #fff; }
  .why-item h4 { font-size: 0.9rem; font-weight: 600; color: #fff; margin-bottom: 3px; }
  .why-item p { font-size: 0.83rem; margin: 0; }
  .cap-panel { background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
  .cap-panel-header { padding: 20px 24px; border-bottom: 1px solid var(--border); background: rgba(124,58,237,0.08); font-family: 'Space Grotesk', sans-serif; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(167,139,250,0.9); }
  .cap-row { display: flex; justify-content: space-between; align-items: center; padding: 13px 24px; border-bottom: 1px solid var(--border2); font-size: 0.84rem; }
  .cap-row:last-child { border-bottom: none; }
  .cap-label { color: var(--muted); }
  .cap-val { color: #fff; font-weight: 500; text-align: right; max-width: 58%; font-size: 0.82rem; }
  .cta-mini { margin: 16px; padding: 18px; background: rgba(124,58,237,0.08); border: 1px solid rgba(124,58,237,0.2); border-radius: 10px; }
  .cta-mini p { font-size: 0.84rem; line-height: 1.65; margin-bottom: 14px; }
  .cta-mini strong { color: rgba(167,139,250,0.95); }
  .visual-section { background: var(--dark3); overflow: hidden; }
  .visual-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: center; }
  .visual-img-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .vis-card { border-radius: 14px; overflow: hidden; border: 1px solid var(--border); background: rgba(255,255,255,0.03); position: relative; }
  .vis-card:first-child { grid-column: span 2; }
  .vis-card-inner { display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
  .vis-label { position: absolute; bottom: 0; left: 0; right: 0; padding: 12px 16px; background: linear-gradient(to top, rgba(6,6,16,0.95) 0%, transparent 100%); }
  .vis-label-text { font-family: 'Space Grotesk', sans-serif; font-size: 0.78rem; font-weight: 700; color: rgba(255,255,255,0.9); }
  .vis-label-sub { font-size: 0.7rem; color: var(--muted); margin-top: 2px; }
  .process-section { background: var(--dark); }
  .process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative; }
  .process-steps::before { content: ''; position: absolute; top: 27px; left: 12%; right: 12%; height: 1px; background: var(--border); }
  .process-step { text-align: center; padding: 0 12px; }
  .step-circle { width: 54px; height: 54px; border-radius: 50%; background: var(--dark2); border: 1px solid var(--border); margin: 0 auto 22px; display: flex; align-items: center; justify-content: center; position: relative; z-index: 1; }
  .step-circle-inner { width: 36px; height: 36px; border-radius: 50%; background: var(--grad); display: flex; align-items: center; justify-content: center; font-family: 'Space Grotesk', sans-serif; font-size: 0.85rem; font-weight: 800; color: #fff; }
  .process-step h3 { font-size: 0.95rem; margin-bottom: 8px; }
  .process-step p { font-size: 0.82rem; line-height: 1.65; }
  .jobs-section { background: var(--dark3); }
  .jobs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; }
  .job-card { background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-left: 3px solid transparent; border-image: var(--grad) 1; border-radius: 0 10px 10px 0; padding: 18px 20px; }
  .job-card h4 { font-size: 0.88rem; color: #fff; margin-bottom: 5px; }
  .job-card p { font-size: 0.8rem; }
  .cta-band { position: relative; overflow: hidden; padding: 88px 0; background: var(--dark2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); text-align: center; }
  .cta-band-orb-1 { position: absolute; width: 500px; height: 500px; border-radius: 50%; background: rgba(37,99,235,0.12); filter: blur(60px); top: -200px; left: -100px; pointer-events: none; }
  .cta-band-orb-2 { position: absolute; width: 400px; height: 400px; border-radius: 50%; background: rgba(219,39,119,0.1); filter: blur(60px); bottom: -150px; right: -80px; pointer-events: none; }
  .cta-band h2 { position: relative; z-index: 1; margin-bottom: 14px; }
  .cta-band p { position: relative; z-index: 1; max-width: 500px; margin: 0 auto 32px; }
  .cta-actions { position: relative; z-index: 1; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .contact-section { background: var(--dark); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 52px; align-items: start; }
  .contact-info { display: flex; flex-direction: column; gap: 20px; }
  .contact-item { display: flex; gap: 14px; }
  .contact-icon { width: 40px; height: 40px; flex-shrink: 0; border-radius: 9px; background: rgba(124,58,237,0.12); border: 1px solid rgba(124,58,237,0.2); display: flex; align-items: center; justify-content: center; }
  .contact-icon svg { width: 17px; height: 17px; stroke: rgba(167,139,250,0.9); fill: none; }
  .contact-lbl { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
  .contact-val { font-size: 0.9rem; color: #fff; font-weight: 500; margin-top: 3px; }
  .contact-val a { color: rgba(167,139,250,0.9); }
  .accepts-box { background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-top: 8px; }
  .accepts-title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 12px; }
  .accepts-item { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; color: var(--muted2); padding: 4px 0; }
  .contact-form { background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 16px; padding: 32px; }
  .form-row { margin-bottom: 16px; }
  .form-label { display: block; font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.5); margin-bottom: 7px; letter-spacing: 0.02em; }
  .form-input, .form-select, .form-textarea { width: 100%; background: rgba(255,255,255,0.04); border: 1.5px solid var(--border); border-radius: 8px; color: #fff; font-family: 'Inter', sans-serif; font-size: 0.875rem; padding: 11px 14px; transition: border-color 0.15s; outline: none; }
  .form-input::placeholder, .form-textarea::placeholder { color: rgba(255,255,255,0.2); }
  .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--purple); background: rgba(124,58,237,0.06); }
  .form-select { appearance: none; cursor: pointer; }
  .form-select option { background: #1a1a3e; color: #fff; }
  .form-textarea { min-height: 110px; resize: vertical; }
  .form-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .form-submit { width: 100%; justify-content: center; margin-top: 6px; font-size: 0.9rem; }
  footer { background: var(--dark2); border-top: 1px solid var(--border); padding: 52px 0 28px; }
  .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 44px; padding-bottom: 40px; border-bottom: 1px solid var(--border); margin-bottom: 28px; }
  .footer-brand p { font-size: 0.83rem; margin-top: 14px; max-width: 240px; color: var(--muted); }
  .footer-col-title { font-family: 'Space Grotesk', sans-serif; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 16px; }
  .footer-col ul { display: flex; flex-direction: column; gap: 9px; }
  .footer-col ul a { font-size: 0.83rem; color: var(--muted); transition: color 0.15s; }
  .footer-col ul a:hover { color: rgba(167,139,250,0.9); }
  .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
  .footer-bottom p { font-size: 0.77rem; color: rgba(255,255,255,0.2); }
  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { display: none; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .why-grid { grid-template-columns: 1fr; gap: 36px; }
    .contact-grid { grid-template-columns: 1fr; }
    .process-steps { grid-template-columns: 1fr 1fr; gap: 36px; }
    .process-steps::before { display: none; }
    .footer-top { grid-template-columns: 1fr 1fr; }
    .visual-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .section { padding: 64px 0; }
    .nav-links, .nav-cta .btn { display: none; }
    .nav-hamburger { display: block; }
    .services-grid { grid-template-columns: 1fr; }
    .form-cols { grid-template-columns: 1fr; }
    .footer-top { grid-template-columns: 1fr; }
    .process-steps { grid-template-columns: 1fr; }
  }
</style>

<!-- Nav -->
<nav id="mainNav">
  <div class="nav-top-line"></div>
  <div class="container nav-inner">
    <a href="/" class="logo">
      <svg width="38" height="32" viewBox="0 0 38 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="lg1" x1="0" y1="0" x2="38" y2="32" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#2563eb"/><stop offset="50%" stop-color="#7c3aed"/><stop offset="100%" stop-color="#db2777"/>
